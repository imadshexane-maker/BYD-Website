  contact={phone:gv('ct-phone',contact.phone),wa:gv('ct-wa',contact.wa),email:gv('ct-email',contact.email),addr:gv('ct-addr',contact.addr),loc:gv('ct-loc',contact.loc),hours:gv('ct-hours',contact.hours)};
}

