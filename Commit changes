function openDet(ci){
  const car=cars[ci];const lc=car[lang]||car.ku;const t=TR[lang];
  dImgs=car.images&&car.images.length?car.images:[];dIdx=0;
  document.getElementById('dt-type').textContent=lc.type;
  document.getElementById('dt-name').textContent=lc.name;
  document.getElementById('dt-short').textContent=lc.desc;
  const ld=document.getElementById('dt-long');
  if(lc.longDesc&&lc.longDesc.trim()){ld.textContent=lc.longDesc;ld.style.display='block';}else{ld.style.display='none';}
  document.getElementById('dt-plbl').textContent=t.priceLbl;
  document.getElementById('dt-price').textContent=car.price+' '+(car.cur||'USD');
  document.getElementById('dt-cta').textContent=t.detCta;
  document.getElementById('dt-specs').innerHTML=(lc.specs||[]).map(s=>`<div class="spec-c"><div class="spec-l">${s.l}</div><div class="spec-v">${s.v}</div></div>`).join('');
  document.getElementById('dm-img').src=dImgs[0]||`https://via.placeholder.com/800x400/141414/333?text=${encodeURIComponent(lc.name)}`;
  const hm=dImgs.length>1;
  document.getElementById('dthumbs').innerHTML=hm?dImgs.map((src,i)=>`<img class="det-thumb${i===0?' active':''}" id="dth-${i}" src="${src}" onclick="dGo(${i})">`).join(''):'';
  document.getElementById('ddots').innerHTML=hm?dImgs.map((_,i)=>`<div class="ddot${i===0?' active':''}" id="ddt-${i}" onclick="dGo(${i})"></div>`).join(''):'';
  document.querySelectorAll('.dgnav').forEach(b=>b.style.display=hm?'flex':'none');
  document.getElementById('det-modal').classList.add('show');
  document.body.style.overflow='hidden';
}
function dNav(dir){if(!dImgs.length)return;dGo((dIdx+dir+dImgs.length)%dImgs.length);}
function dGo(i){dIdx=i;document.getElementById('dm-img').src=dImgs[i];document.querySelectorAll('.det-thumb').forEach((t,ti)=>t.classList.toggle('active',ti===i));document.querySelectorAll('.ddot').forEach((d,di)=>d.classList.toggle('active',di===i));}
function closeDet(){document.getElementById('det-modal').classList.remove('show');document.body.style.overflow='';}

// ==================== INVENTORY ====================
const ISTC=['available','reserved','sold'];
const ICLRS={'#ffffff':'سپی','#000000':'ریش','#c0392b':'سووری','#2980b9':'شین','#27ae60':'سەوز','#f39c12':'زەرد','#8e44ad':'مۆر','#7f8c8d':'مزمز','#d35400':'پرتەقاڵی','#bdc3c7':'سیلڤەر'};
const ICLRK=Object.keys(ICLRS);

function stLbl(s){const t=TR[lang];return s==='available'?t.invAvail:s==='reserved'?t.invRes:t.invSold;}
function renderInv(){
  const t=TR[lang];
  const tot=inventory.length,av=inventory.filter(r=>r.s==='available').length,so=inventory.filter(r=>r.s==='sold').length,re=inventory.filter(r=>r.s==='reserved').length;
  document.getElementById('inv-sum').innerHTML=`<div class="isc"><div class="isc-n" style="color:var(--text)">${tot}</div><div class="isc-l">Total</div></div><div class="isc"><div class="isc-n" style="color:#27ae60">${av}</div><div class="isc-l">${t.invAvail}</div></div><div class="isc"><div class="isc-n" style="color:var(--s)">${re}</div><div class="isc-l">${t.invRes}</div></div><div class="isc"><div class="isc-n" style="color:var(--p)">${so}</div><div class="isc-l">${t.invSold}</div></div>`;
  document.getElementById('inv-body').innerHTML=inventory.map((r,i)=>`<tr><td><input id="iv${i}n" value="${r.n||''}"></td><td><input id="iv${i}ch" value="${r.ch||''}" style="direction:ltr;font-size:11px"></td><td><div class="cc"><div class="cdot" style="background:${r.c||'#fff'}" onclick="ivCC(${i})" title="${ICLRS[r.c]||''}"></div><span style="font-size:10px;color:var(--muted)">${ICLRS[r.c]||''}</span></div></td><td><button class="ist ${r.s||'available'}" onclick="ivCS(${i})">${stLbl(r.s||'available')}</button></td><td><button class="idel" onclick="ivDel(${i})">✕</button></td></tr>`).join('');
}
function ivCol(){inventory=inventory.map((r,i)=>({...r,n:gv(`iv${i}n`,r.n),ch:gv(`iv${i}ch`,r.ch)}));}
function ivCS(i){ivCol();const c=ISTC.indexOf(inventory[i].s||'available');inventory[i].s=ISTC[(c+1)%3];renderInv();}
function ivCC(i){ivCol();const c=ICLRK.indexOf(inventory[i].c||'#ffffff');inventory[i].c=ICLRK[(c+1)%ICLRK.length];renderInv();}
function addInv(){ivCol();inventory.push({n:'BYD',ch:'',c:'#ffffff',s:'available'});renderInv();}
function ivDel(i){ivCol();inventory.splice(i,1);renderInv();}
function saveInv(){ivCol();sl('byd_iv',inventory);renderInv();showToast(TR[lang].tInv,'ok');}

// ==================== EXPORT/IMPORT ====================
function exportData(){
  collectAll();
  const d={site:siteData,cars,contact,design,inventory,v:6,date:new Date().toISOString()};
  const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([JSON.stringify(d)],{type:'application/json'}));a.download='byd-backup-'+new Date().toISOString().slice(0,10)+'.json';a.click();
}
function importData(inp){
  const f=inp.files[0];if(!f)return;
  const r=new FileReader();
  r.onload=e=>{
    try{
      const d=JSON.parse(e.target.result);
      if(d.site)siteData=d.site;if(d.cars)cars=d.cars;if(d.contact)contact=d.contact;if(d.design)design=d.design;if(d.inventory)inventory=d.inventory;
      saveAll();applyDesignAll();fillContactFields();applyPage();renderCarsGrid();renderCarsAdmin();renderHeroFields();renderAboutFields();renderInv();
      showToast(TR[lang].tImport,'ok');
    }catch(err){showToast(TR[lang].tErr,'er');}
  };r.readAsText(f);inp.value='';
}

function fillContactFields(){
  const f=(id,v)=>{const el=document.getElementById(id);if(el)el.value=v||'';};
  f('ct-phone',contact.phone);f('ct-wa',contact.wa);f('ct-email',contact.email);f('ct-addr',contact.addr);f('ct-loc',contact.loc);f('ct-hours',contact.hours);
}

// ==================== APPLY DESIGN ALL ====================
function applyDesignAll(){
  applyColor(design.color,true);
  applySecondary(design.secondary||'#c9a84c',true);
  applyBg(design.bgColor||'#0a0a0a',true);
  applyFont(design.font||'Tajawal',true);
  applyFontSize(design.fontSize||'16px',null,true);
  applyTheme();
  renderSwatches();
  applyLogo();
  const fs=document.getElementById('font-sel');if(fs)fs.value=design.font||'Tajawal';
  if(design.heroCarImg){document.getElementById('hero-car-img').src=design.heroCarImg;const p=document.getElementById('hcp');if(p)p.innerHTML=`<img src="${design.heroCarImg}" style="width:100%;height:90px;object-fit:contain;background:var(--bg3);border-radius:8px;margin-top:6px">`;}
  if(design.bgImage){document.getElementById('hero-bg-img').style.backgroundImage=`url(${design.bgImage})`;}
}

// ==================== TOAST ====================
function showToast(msg,type='ok'){const t=document.getElementById('toast');t.textContent=msg;t.className=`toast ${type} show`;setTimeout(()=>t.classList.remove('show'),3500);}

// ==================== INIT ====================
async function init(){
  try { loadAll(); } catch(e){ console.warn('loadAll',e); }
  try { applyDesignAll(); } catch(e){ console.warn('applyDesignAll',e); }
  try { fillContactFields(); } catch(e){ console.warn('fillContactFields',e); }
  try { setLang('ku',document.querySelector('.lb2')); } catch(e){ console.warn('setLang',e); }
  try { renderCarsGrid(); } catch(e){ console.warn('renderCarsGrid',e); }
  try { renderHeroFields(); } catch(e){ console.warn('renderHeroFields',e); }
  try { renderAboutFields(); } catch(e){ console.warn('renderAboutFields',e); }
  try { renderCarsAdmin(); } catch(e){ console.warn('renderCarsAdmin',e); }
  try { renderInv(); } catch(e){ console.warn('renderInv',e); }
  // Always hide loading screen no matter what
  setTimeout(()=>{
    const ls=document.getElementById('ls');
    if(ls){ls.classList.add('hide');setTimeout(()=>{if(ls.parentNode)ls.parentNode.removeChild(ls);},600);}
  },1500);
}
init();
</script>
