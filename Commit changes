function applyBg(c,skip){design.bgColor=c;const hb=document.getElementById('hero-bg');if(hb)hb.style.background=c;const e=document.getElementById('cc-bg');if(e)e.value=c;document.querySelectorAll('.csbg').forEach(s=>s.classList.toggle('sel',s.dataset.c===c));if(!skip)scheduleSave();}
function applyFont(f,skip){design.font=f;const lk=document.getElementById('gfont');lk.href=`https://fonts.googleapis.com/css2?family=${f}:wght@300;400;500;700;900&family=Bebas+Neue&display=swap`;document.documentElement.style.setProperty('--font',`'${f.replace(/\+/g,' ')}',sans-serif`);if(!skip)scheduleSave();}
function applyFontSize(sz,btn,skip){design.fontSize=sz;document.documentElement.style.setProperty('--fs',sz);document.querySelectorAll('.fs-active').forEach(b=>{b.classList.remove('fs-active');b.style.background='';b.style.borderColor='';b.style.color='';});if(btn){btn.classList.add('fs-active');btn.style.background='var(--p)';btn.style.borderColor='var(--p)';btn.style.color='#fff';}if(!skip)scheduleSave();}

