function gN(ci,dir,e){e&&e.stopPropagation();const imgs=cars[ci].images||[];if(imgs.length<2)return;let idx=((window.gIdx[ci]||0)+dir+imgs.length)%imgs.length;window.gIdx[ci]=idx;document.getElementById('gi-'+ci).src=imgs[idx];document.querySelectorAll(`#cg-${ci} .gdot`).forEach((d,i)=>d.classList.toggle('a',i===idx));}
function gG(ci,di,e){e&&e.stopPropagation();window.gIdx[ci]=di;document.getElementById('gi-'+ci).src=(cars[ci].images||[])[di]||'';document.querySelectorAll(`#cg-${ci} .gdot`).forEach((d,i)=>d.classList.toggle('a',i===di));}

