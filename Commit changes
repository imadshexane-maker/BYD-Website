  <!-- DESIGN -->
  <div class="adm-sec">
    <h3>🎨 دیزاین</h3>
    <!-- Color 1 -->
    <div class="af">
      <label style="display:flex;align-items:center;gap:6px"><div id="c1p" style="width:16px;height:16px;border-radius:50%;background:var(--p);border:2px solid #555;flex-shrink:0"></div>ڕەنگی یەکەم (دوگمەکان، هایلایت)</label>
      <div style="font-size:9px;color:var(--muted);margin-bottom:5px;letter-spacing:1px">🔴 سووری — مات</div><div class="crow" id="c1a"></div>
      <div style="font-size:9px;color:var(--muted);margin:6px 0 4px;letter-spacing:1px">🟠 گەرم</div><div class="crow" id="c1b"></div>
      <div style="font-size:9px;color:var(--muted);margin:6px 0 4px;letter-spacing:1px">🔵 شین — مات</div><div class="crow" id="c1c"></div>
      <div style="font-size:9px;color:var(--muted);margin:6px 0 4px;letter-spacing:1px">🟢 سەوز — تیری</div><div class="crow" id="c1d"></div>
      <div style="font-size:9px;color:var(--muted);margin:6px 0 4px;letter-spacing:1px">⬛ کلاسیک — مات</div><div class="crow" id="c1e"></div>
      <div style="display:flex;gap:7px;margin-top:7px;align-items:center">
        <input type="color" id="cc1" value="#E63327" style="width:38px;height:32px;border-radius:8px;border:none;cursor:pointer;padding:2px;background:var(--bg3);">
        <span style="font-size:11px;color:var(--muted)">ڕەنگی تایبەت</span>
      </div>
    </div>
    <div style="height:1px;background:var(--border);margin:10px 0"></div>
    <!-- Color 2 -->
    <div class="af">
      <label style="display:flex;align-items:center;gap:6px"><div id="c2p" style="width:16px;height:16px;border-radius:50%;background:var(--s);border:2px solid #555;flex-shrink:0"></div>ڕەنگی دووەم (نرخ، خەت، لۆگۆ)</label>
      <div style="font-size:9px;color:var(--muted);margin-bottom:5px;letter-spacing:1px">🥇 زێڕ — سیلڤەر — مات</div><div class="crow" id="c2a"></div>
      <div style="font-size:9px;color:var(--muted);margin:6px 0 4px;letter-spacing:1px">🔵 شین — فیرۆزەیی</div><div class="crow" id="c2b"></div>
      <div style="font-size:9px;color:var(--muted);margin:6px 0 4px;letter-spacing:1px">🟢 سەوز — زەیتوون</div><div class="crow" id="c2c"></div>
      <div style="display:flex;gap:7px;margin-top:7px;align-items:center">
        <input type="color" id="cc2" value="#c9a84c" style="width:38px;height:32px;border-radius:8px;border:none;cursor:pointer;padding:2px;background:var(--bg3);">
        <span style="font-size:11px;color:var(--muted)">ڕەنگی تایبەت</span>
      </div>
