<!-- THEME TOGGLE -->
<button id="theme-btn" onclick="toggleTheme()" title="Dark/Light">🌙</button>

<!-- ADMIN PANEL -->
<div id="adm">
  <div class="adm-hd">
    <h2>⚙️ دەسکاریکردن</h2>
    <div style="display:flex;align-items:center;gap:7px">
      <button class="adm-logout" onclick="logout()">🚪 دەرچوون</button>
      <button class="adm-x" onclick="toggleAdm()">✕</button>
