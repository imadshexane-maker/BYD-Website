function renderSwatches(){try{
  const mk=(arr,id,cls,fn)=>{const el=document.getElementById(id);if(el)el.innerHTML=arr.map(c=>`<div class="cs ${cls}${c===design.color&&cls==='cs1 '?' sel':c===design.secondary&&cls==='cs2 '?' sel':''}" data-c="${c}" style="background:${c}" onclick="${fn}('${c}')" title="${c}"></div>`).join('');};
  Object.entries(CP1).forEach(([k,arr],i)=>mk(arr,'c1'+['a','b','c','d','e'][i],'cs1 ','applyColor'));
  Object.entries(CP2).forEach(([k,arr],i)=>mk(arr,'c2'+['a','b','c'][i],'cs2 ','applySecondary'));
  const be=document.getElementById('bg-swatches');if(be)be.innerHTML=BG_PRESETS.map(c=>`<div class="cs csbg${c===design.bgColor?' sel':''}" data-c="${c}" style="background:${c};border:2px solid ${c===(design.bgColor)?' white':'#444'}" onclick="applyBg('${c}')" title="${c}"></div>`).join('');
  const cc1=document.getElementById('cc1');if(cc1){cc1.value=design.color;cc1.onchange=function(){applyColor(this.value);};}
  const cc2=document.getElementById('cc2');if(cc2){cc2.value=design.secondary;cc2.onchange=function(){applySecondary(this.value);};}
  const ccb=document.getElementById('cc-bg');if(ccb){ccb.value=design.bgColor||'#0a0a0a';ccb.onchange=function(){applyBg(this.value);};}}catch(e){console.warn('renderSwatches',e);}
}

