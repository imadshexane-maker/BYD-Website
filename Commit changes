  siteData[adminLang]={...s,shopName:gv('ah-sn',s.shopName),badge:gv('ah-bg',s.badge),t1:gv('ah-t1',s.t1),t2:gv('ah-t2',s.t2),sub:gv('ah-sub',s.sub),btn1:gv('ah-b1',s.btn1),statM:gv('ah-sm',s.statM),statC:gv('ah-sc',s.statC),statY:gv('ah-sy',s.statY),ctTitle:gv('ah-ct',s.ctTitle),footerCopy:gv('ah-fc',s.footerCopy),abtTitle:gv('aa-t',s.abtTitle),abtBody:gv('aa-b',s.abtBody),f1ic:gv('af1i',s.f1ic),f1t:gv('af1t',s.f1t),f1d:gv('af1d',s.f1d),f2ic:gv('af2i',s.f2ic),f2t:gv('af2t',s.f2t),f2d:gv('af2d',s.f2d),f3ic:gv('af3i',s.f3ic),f3t:gv('af3t',s.f3t),f3d:gv('af3d',s.f3d)};
