    <div class="af"><label>ڕەنگی باگراوند</label>
      <div style="display:flex;gap:7px;align-items:center;flex-wrap:wrap;margin-bottom:7px" id="bg-swatches"></div>
      <div style="display:flex;gap:7px;align-items:center">
        <input type="color" id="cc-bg" value="#0a0a0a" style="width:38px;height:32px;border-radius:8px;border:none;cursor:pointer;padding:2px;background:var(--bg3);">
        <span style="font-size:11px;color:var(--muted)">ڕەنگی تایبەت</span>
      </div>
    </div>
    <div class="af"><label>وێنەی باگراوند (ئەگەر دەتەوێت)</label>
