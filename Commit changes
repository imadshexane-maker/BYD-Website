  const d=now.getDate(),mo=now.getMonth(),y=now.getFullYear(),dw=now.getDay();
  const L=lang||'ku';
  document.getElementById('clk-date').textContent=`${days[L][dw]} ${d} ${months[L][mo]} ${y}`;
}
