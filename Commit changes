<!DOCTYPE html>
<html lang="ku" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BYD فرۆشگا</title>
<link id="gfont" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;900&family=Bebas+Neue&display=swap" rel="stylesheet">
<style>
:root{
  --p:#E63327; --s:#c9a84c; --dark:#0a0a0a; --darker:#050505;
  --mid:#141414; --light:#f0f0f0; --muted:#888;
  --bg:#0a0a0a; --bg2:#141414; --bg3:#1e1e1e;
  --text:#f0f0f0; --text2:rgba(240,240,240,0.65);
  --border:#1e1e1e; --font:'Tajawal',sans-serif; --fs:16px;
}
body.light-mode{
  --dark:#f5f5f5; --darker:#ebebeb; --mid:#ffffff; --bg:#f5f5f5;
  --bg2:#ffffff; --bg3:#eeeeee; --text:#111111; --text2:rgba(0,0,0,0.6);
  --border:#dddddd; --muted:#666;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:var(--font);font-size:var(--fs);background:var(--bg);color:var(--text);overflow-x:hidden;transition:background .3s,color .3s;}

/* ===== LOADING ===== */
#ls{position:fixed;inset:0;background:var(--darker);z-index:99999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;transition:opacity .5s;}
#ls.hide{opacity:0;pointer-events:none;}
.ll{font-family:'Bebas Neue',sans-serif;font-size:48px;letter-spacing:6px;color:white;}
.ll span{color:var(--p);}
.lb{width:200px;height:3px;background:#222;border-radius:10px;overflow:hidden;}
.lf{height:100%;background:var(--p);border-radius:10px;animation:loadbar 1.5s ease forwards;}
@keyframes loadbar{from{width:0}to{width:100%}}

/* ===== FLAGS ===== */
.flag-ku{display:inline-flex;align-items:center;justify-content:center;width:22px;height:15px;border-radius:2px;overflow:hidden;position:relative;flex-shrink:0;background:linear-gradient(to bottom,#ef2b2d 33.3%,#fff 33.3% 66.6%,#007a3d 66.6%);}
.flag-ku::after{content:'✦';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:7px;color:#ef7d00;line-height:1;}

/* ===== PW MODAL ===== */
#pw-modal{position:fixed;inset:0;background:rgba(0,0,0,.88);backdrop-filter:blur(8px);z-index:99998;display:none;align-items:center;justify-content:center;}
#pw-modal.show{display:flex;}
.pw-box{background:var(--bg2);border:1px solid var(--border);border-radius:20px;padding:40px;width:360px;text-align:center;}
.pw-box h2{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:2px;margin:12px 0 8px;}
.pw-box p{font-size:14px;color:var(--muted);margin-bottom:22px;}
.pw-inp{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:10px;color:var(--text);font-family:var(--font);font-size:16px;padding:12px;outline:none;text-align:center;letter-spacing:3px;margin-bottom:12px;direction:ltr;transition:border-color .2s;}
.pw-inp:focus{border-color:var(--p);}
.pw-inp.wrong{border-color:var(--p);animation:shake .3s;}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-8px)}75%{transform:translateX(8px)}}
.pw-btn{width:100%;background:var(--p);color:#fff;border:none;padding:13px;border-radius:10px;font-family:var(--font);font-weight:700;font-size:16px;cursor:pointer;margin-bottom:10px;}
.pw-cancel{background:transparent;border:none;color:var(--muted);font-family:var(--font);font-size:14px;cursor:pointer;}
.pw-err{color:var(--p);font-size:13px;margin-top:6px;display:none;}

/* ===== DETAIL MODAL ===== */
#det-modal{position:fixed;inset:0;background:rgba(0,0,0,.92);backdrop-filter:blur(14px);z-index:88888;display:none;align-items:center;justify-content:center;padding:20px;}
#det-modal.show{display:flex;}
.det-box{background:var(--bg2);border:1px solid var(--border);border-radius:24px;width:100%;max-width:920px;max-height:90vh;overflow-y:auto;position:relative;}
.det-close{position:sticky;top:16px;float:left;margin:16px;background:rgba(255,255,255,.1);border:none;color:#fff;width:40px;height:40px;border-radius:50%;font-size:20px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:5;}
.det-close:hover{background:var(--p);}
.det-gall{position:relative;height:380px;background:var(--darker);border-radius:20px 20px 0 0;overflow:hidden;}
.det-gall img{width:100%;height:100%;object-fit:contain;transition:opacity .3s;}
.dgnav{position:absolute;top:50%;transform:translateY(-50%);background:rgba(0,0,0,.7);border:none;color:#fff;width:44px;height:44px;border-radius:50%;cursor:pointer;font-size:24px;display:flex;align-items:center;justify-content:center;z-index:3;}
.dgnav:hover{background:var(--p);}
.dgnav.prev{right:16px;}.dgnav.next{left:16px;}
.det-thumbs{display:flex;gap:8px;padding:12px 18px;background:var(--darker);overflow-x:auto;}
.det-thumb{width:68px;height:48px;object-fit:cover;border-radius:8px;cursor:pointer;border:2px solid transparent;flex-shrink:0;opacity:.6;transition:all .2s;}
.det-thumb.active{border-color:var(--p);opacity:1;}
.ddots{position:absolute;bottom:10px;left:50%;transform:translateX(-50%);display:flex;gap:6px;z-index:3;}
.ddot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.4);cursor:pointer;transition:all .2s;}
.ddot.active{background:#fff;transform:scale(1.3);}
.det-body{padding:26px;}
.det-type{font-size:12px;color:var(--p);font-weight:700;letter-spacing:3px;text-transform:uppercase;margin-bottom:8px;}
.det-name{font-family:'Bebas Neue',sans-serif;font-size:44px;letter-spacing:2px;margin-bottom:8px;}
.det-short{font-size:15px;color:var(--text2);line-height:1.8;margin-bottom:12px;}
.det-long{font-size:14px;color:var(--text2);line-height:1.9;margin-bottom:22px;padding:14px;background:var(--bg3);border-radius:12px;border:1px solid var(--border);}
.det-specs{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px;margin-bottom:22px;}
.spec-c{background:var(--bg3);border-radius:12px;padding:13px;border:1px solid var(--border);}
.spec-l{font-size:11px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:3px;}
.spec-v{font-size:16px;font-weight:700;color:var(--text);}
.det-prow{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;background:var(--bg3);border-radius:14px;padding:18px;border:1px solid var(--border);}
.det-price{font-family:'Bebas Neue',sans-serif;font-size:40px;color:var(--s);}
.det-cta{background:var(--p);color:#fff;border:none;padding:13px 28px;border-radius:50px;font-family:var(--font);font-weight:700;font-size:15px;cursor:pointer;transition:all .3s;box-shadow:0 8px 24px rgba(0,0,0,.3);}
.det-cta:hover{opacity:.9;}

/* ===== ADMIN ===== */
#adm-btn{position:fixed;bottom:24px;left:24px;z-index:10000;background:var(--p);color:#fff;border:none;padding:13px 20px;border-radius:50px;font-family:var(--font);font-size:14px;font-weight:700;cursor:pointer;box-shadow:0 8px 32px rgba(0,0,0,.4);transition:all .3s;display:flex;align-items:center;gap:8px;}
#adm-btn:hover{transform:scale(1.05);}
#adm{position:fixed;top:0;left:0;width:440px;height:100vh;background:var(--bg2);border-right:2px solid var(--p);z-index:9999;transform:translateX(-100%);transition:transform .4s cubic-bezier(.4,0,.2,1);overflow-y:auto;}
#adm.open{transform:translateX(0);}
.adm-hd{background:linear-gradient(to left,var(--s),var(--p));padding:16px 20px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:10;}
.adm-hd h2{font-size:16px;font-weight:900;}
.adm-logout{background:rgba(0,0,0,.2);border:1px solid rgba(255,255,255,.3);color:#fff;padding:5px 10px;border-radius:20px;font-family:var(--font);font-size:12px;cursor:pointer;}
.adm-x{background:rgba(255,255,255,.2);border:none;color:#fff;width:32px;height:32px;border-radius:50%;font-size:17px;cursor:pointer;}
.adm-sec{padding:16px 20px;border-bottom:1px solid var(--border);}
.adm-sec h3{color:var(--s);font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-bottom:12px;}
.adm-tabs{display:flex;gap:3px;margin-bottom:12px;background:var(--bg3);padding:3px;border-radius:10px;}
.adm-tab{flex:1;background:transparent;border:none;color:var(--muted);padding:7px;border-radius:8px;font-family:var(--font);font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;}
.adm-tab.active{background:var(--p);color:#fff;}
.af{margin-bottom:10px;}
.af label{display:block;font-size:11px;color:var(--muted);margin-bottom:4px;font-weight:500;}
.af input,.af textarea,.af select{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:var(--font);font-size:13px;padding:8px 10px;outline:none;transition:border-color .2s;}
.af input:focus,.af textarea:focus,.af select:focus{border-color:var(--p);}
.af textarea{height:64px;resize:vertical;}
.af select option{background:var(--bg2);}
.ce{background:var(--bg3);border:1px solid var(--border);border-radius:12px;padding:13px;margin-bottom:9px;position:relative;}
.ce-num{color:var(--p);font-weight:900;font-size:11px;letter-spacing:2px;margin-bottom:9px;}
.ce-rm{position:absolute;top:10px;left:10px;background:rgba(230,51,39,.2);border:none;color:var(--p);width:24px;height:24px;border-radius:50%;font-size:14px;cursor:pointer;}
.sv{background:var(--p);color:#fff;border:none;padding:12px 16px;border-radius:10px;font-family:var(--font);font-weight:700;font-size:14px;cursor:pointer;width:100%;transition:all .2s;margin-top:5px;}
.sv:hover{opacity:.9;}
.sv.gr{background:#1a6b3c;}
.sv.bl{background:#1d4ed8;}
.add-c{background:transparent;color:var(--s);border:1px dashed var(--s);padding:9px 13px;border-radius:8px;font-family:var(--font);font-weight:600;font-size:12px;cursor:pointer;width:100%;transition:all .2s;margin-top:4px;}
.add-c:hover{background:rgba(201,168,76,.1);}
.cs{width:30px;height:30px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:all .2s;flex-shrink:0;}
.cs.sel{border-color:#fff;transform:scale(1.15);}
.crow{display:flex;gap:6px;flex-wrap:wrap;margin-top:5px;}
#si{text-align:center;font-size:11px;color:#27ae60;margin-top:5px;opacity:0;transition:opacity .4s;}

/* INVENTORY */
.inv-wrap{overflow-x:auto;margin-top:10px;}
.inv-t{width:100%;border-collapse:collapse;font-size:12px;}
.inv-t th{background:var(--bg3);color:var(--s);font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:8px 8px;text-align:right;border-bottom:1px solid var(--border);}
.inv-t td{padding:7px 8px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle;}
.inv-t input{background:transparent;border:none;color:var(--text);font-family:var(--font);font-size:12px;width:100%;outline:none;padding:2px 3px;border-bottom:1px solid transparent;}
.inv-t input:focus{border-bottom-color:var(--p);}
.cc{display:flex;align-items:center;gap:5px;}
.cdot{width:16px;height:16px;border-radius:50%;border:2px solid #444;cursor:pointer;flex-shrink:0;}
.ist{padding:3px 8px;border-radius:20px;font-size:10px;font-weight:700;cursor:pointer;white-space:nowrap;border:none;font-family:var(--font);}
.ist.available{background:rgba(39,174,96,.15);color:#27ae60;border:1px solid rgba(39,174,96,.3);}
.ist.sold{background:rgba(230,51,39,.15);color:var(--p);border:1px solid rgba(230,51,39,.3);}
.ist.reserved{background:rgba(201,168,76,.15);color:var(--s);border:1px solid rgba(201,168,76,.3);}
.idel{background:rgba(230,51,39,.15);border:none;color:var(--p);width:24px;height:24px;border-radius:50%;cursor:pointer;font-size:13px;}
.isum{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:10px;}
.isc{flex:1;min-width:55px;background:var(--bg3);border-radius:10px;padding:9px 7px;text-align:center;border:1px solid var(--border);}
.isc-n{font-family:'Bebas Neue',sans-serif;font-size:24px;line-height:1;}
.isc-l{font-size:9px;color:var(--muted);margin-top:2px;}
.iadd{background:transparent;color:var(--s);border:1px dashed var(--s);padding:7px 12px;border-radius:8px;font-family:var(--font);font-weight:600;font-size:12px;cursor:pointer;width:100%;margin-top:9px;}

/* TOAST */
.toast{position:fixed;top:24px;right:80px;padding:12px 18px;border-radius:12px;font-weight:700;font-size:13px;z-index:99999;opacity:0;transform:translateY(-10px);transition:all .3s;pointer-events:none;}
.toast.show{opacity:1;transform:translateY(0);}
.toast.ok{background:#27ae60;color:#fff;}
.toast.er{background:#e74c3c;color:#fff;}

/* ===== WHATSAPP ===== */
#wa-btn{position:fixed;bottom:24px;right:24px;z-index:10000;width:58px;height:58px;border-radius:50%;background:#25d366;border:none;cursor:pointer;box-shadow:0 8px 32px rgba(37,211,102,.5);display:flex;align-items:center;justify-content:center;animation:wabounce 2s ease-in-out infinite;}
@keyframes wabounce{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-8px) scale(1.05)}70%{transform:translateY(-4px) scale(1.02)}}
#wa-btn:hover{animation:none;transform:scale(1.1);}
#wa-btn svg{width:30px;height:30px;fill:#fff;}

/* ===== DARK/LIGHT TOGGLE ===== */
#theme-btn{position:fixed;bottom:24px;right:96px;z-index:10000;width:44px;height:44px;border-radius:50%;background:var(--bg3);border:1px solid var(--border);cursor:pointer;font-size:20px;display:flex;align-items:center;justify-content:center;transition:all .3s;box-shadow:0 4px 16px rgba(0,0,0,.3);}
#theme-btn:hover{transform:scale(1.1);}

/* ===== NAV ===== */
nav{position:fixed;top:0;left:0;right:0;z-index:1000;padding:0 60px;height:80px;display:flex;align-items:center;justify-content:space-between;background:linear-gradient(to bottom,rgba(5,5,5,.95),transparent);backdrop-filter:blur(10px);}
body.light-mode nav{background:linear-gradient(to bottom,rgba(245,245,245,.98),transparent);}
.nav-logo-wrap{display:flex;align-items:center;gap:10px;}
.nav-logo-img{height:36px;object-fit:contain;display:none;}
.nav-logo-img.show{display:block;}
.nav-logo{font-family:'Bebas Neue',sans-serif;font-size:30px;color:var(--text);letter-spacing:4px;}
.nav-logo span{color:var(--p);}
.nav-links{display:flex;gap:24px;list-style:none;align-items:center;}
.nav-links a{color:var(--text2);text-decoration:none;font-size:14px;font-weight:500;transition:color .2s;}
.nav-links a:hover{color:var(--text);}
.nav-cta{background:var(--p);color:#fff;padding:9px 20px;border-radius:50px;font-weight:700;font-size:13px;cursor:pointer;border:none;font-family:var(--font);transition:all .2s;}
.nav-cta:hover{transform:scale(1.05);}
.lang-sw{display:flex;gap:3px;background:rgba(128,128,128,.12);border-radius:30px;padding:3px;}
.lb2{background:transparent;border:none;color:var(--text2);padding:5px 9px;border-radius:24px;font-family:var(--font);font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:4px;}
.lb2.active{background:var(--p);color:#fff;}
.lb2:hover:not(.active){color:var(--text);}

/* MOBILE LANG BAR */
#mlb{display:none;position:fixed;top:80px;left:0;right:0;z-index:999;background:var(--bg2);border-bottom:1px solid var(--border);padding:10px 16px;justify-content:center;gap:8px;backdrop-filter:blur(10px);}

/* ===== HERO ===== */
.hero{height:100vh;position:relative;display:flex;align-items:center;overflow:hidden;}
.hero-bg{position:absolute;inset:0;transition:background .5s;}
.hero-bg-img{position:absolute;inset:0;background-size:cover;background-position:center;opacity:.25;transition:opacity .5s;}
.hero-overlay{position:absolute;inset:0;background:radial-gradient(ellipse at 70% 50%,rgba(230,51,39,0.18) 0%,transparent 60%),radial-gradient(ellipse at 20% 80%,rgba(201,168,76,0.1) 0%,transparent 50%);}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(128,128,128,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(128,128,128,.04) 1px,transparent 1px);background-size:60px 60px;}
.hero-content{position:relative;z-index:2;padding:0 60px;max-width:700px;}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(230,51,39,0.15);border:1px solid rgba(230,51,39,0.4);color:var(--p);padding:7px 15px;border-radius:50px;font-size:12px;font-weight:600;letter-spacing:2px;text-transform:uppercase;margin-bottom:26px;}
.hero-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(56px,8vw,108px);line-height:.9;color:var(--text);margin-bottom:26px;letter-spacing:2px;}
.hero-t2{color:var(--s);}
.hero-sub{font-size:17px;color:var(--text2);font-weight:300;line-height:1.75;margin-bottom:40px;max-width:500px;}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap;}
.btn-p{background:var(--p);color:#fff;padding:15px 32px;border-radius:50px;font-weight:700;font-size:15px;border:none;cursor:pointer;font-family:var(--font);transition:all .3s;box-shadow:0 8px 28px rgba(0,0,0,.3);}
.btn-p:hover{transform:translateY(-2px);}
.btn-o{background:transparent;color:var(--text);padding:15px 32px;border-radius:50px;font-weight:600;font-size:15px;border:1px solid rgba(128,128,128,.4);cursor:pointer;font-family:var(--font);transition:all .3s;}
.btn-o:hover{border-color:var(--text);}
.hero-car{position:absolute;left:0;top:50%;transform:translateY(-50%);width:55%;height:75%;object-fit:contain;opacity:.85;filter:drop-shadow(0 40px 80px rgba(0,0,0,.4));animation:float 6s ease-in-out infinite;}
@keyframes float{0%,100%{transform:translateY(-50%) translateX(0)}50%{transform:translateY(-52%) translateX(12px)}}
.hero-stats{position:absolute;bottom:60px;right:60px;display:flex;gap:48px;z-index:2;}
.stat-n{font-family:'Bebas Neue',sans-serif;font-size:46px;color:var(--text);line-height:1;}
.stat-l{font-size:11px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-top:3px;}

/* DATE CLOCK */
.hero-clock{position:absolute;top:100px;right:60px;z-index:3;text-align:center;background:rgba(0,0,0,.35);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:14px 20px;min-width:190px;}
body.light-mode .hero-clock{background:rgba(255,255,255,.7);border-color:rgba(0,0,0,.1);}
.clock-time{font-family:'Bebas Neue',sans-serif;font-size:38px;letter-spacing:3px;line-height:1;color:var(--text);}
.clock-secs{font-size:22px;color:var(--p);}
.clock-date{font-size:12px;color:var(--muted);margin-top:5px;letter-spacing:1px;}

/* ===== SECTIONS ===== */
section{padding:96px 60px;}
.sl{color:var(--p);font-size:11px;font-weight:700;letter-spacing:4px;text-transform:uppercase;margin-bottom:12px;display:flex;align-items:center;gap:12px;}
.sl::after{content:'';display:inline-block;width:40px;height:2px;background:linear-gradient(to left,var(--s),var(--p));}
.st{font-family:'Bebas Neue',sans-serif;font-size:clamp(38px,5vw,62px);color:var(--text);line-height:1;margin-bottom:14px;letter-spacing:2px;}

/* CARS */
#cars-sec{background:var(--darker);}
body.light-mode #cars-sec{background:var(--bg3);}
.cg{display:grid;grid-template-columns:repeat(auto-fill,minmax(310px,1fr));gap:22px;margin-top:56px;}
.cc2{background:var(--bg2);border-radius:20px;overflow:hidden;border:1px solid var(--border);transition:all .4s;cursor:pointer;}
.cc2:hover{transform:translateY(-8px);border-color:var(--p);box-shadow:0 20px 60px rgba(0,0,0,.3);}
.cg-wrap{position:relative;height:215px;background:linear-gradient(135deg,var(--bg3),var(--bg2));overflow:hidden;}
.cg-wrap img{width:100%;height:100%;object-fit:contain;}
.gnav{position:absolute;top:50%;transform:translateY(-50%);background:rgba(0,0,0,.6);border:none;color:#fff;width:30px;height:30px;border-radius:50%;cursor:pointer;font-size:18px;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s;z-index:2;}
.cc2:hover .gnav{opacity:1;}
.gnav.p{right:8px;}.gnav.n{left:8px;}
.gdots{position:absolute;bottom:7px;left:50%;transform:translateX(-50%);display:flex;gap:5px;z-index:2;}
.gdot{width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,.4);cursor:pointer;}
.gdot.a{background:#fff;}
.cbadge{position:absolute;top:12px;right:12px;background:var(--p);color:#fff;padding:3px 10px;border-radius:50px;font-size:10px;font-weight:700;letter-spacing:1px;z-index:2;}
.ci{padding:20px;}
.ctlbl{font-size:10px;color:var(--p);font-weight:700;letter-spacing:3px;text-transform:uppercase;margin-bottom:7px;}
.cname{font-family:'Bebas Neue',sans-serif;font-size:28px;color:var(--text);letter-spacing:2px;margin-bottom:7px;}
.cdesc{font-size:12px;color:var(--muted);line-height:1.6;margin-bottom:16px;}
.cprow{display:flex;align-items:center;justify-content:space-between;}
.cprice{font-family:'Bebas Neue',sans-serif;font-size:24px;color:var(--s);letter-spacing:1px;}
.cpl{font-size:10px;color:var(--muted);}
.cbtns{display:flex;gap:7px;}
.cmore{background:transparent;color:var(--text2);border:1px solid var(--border);padding:8px 13px;border-radius:50px;font-family:var(--font);font-weight:600;font-size:12px;cursor:pointer;transition:all .2s;}
.cmore:hover{border-color:var(--text);color:var(--text);}
.cask{background:var(--p);color:#fff;border:none;padding:8px 16px;border-radius:50px;font-family:var(--font);font-weight:700;font-size:12px;cursor:pointer;}

/* ABOUT */
#abt-sec{background:var(--dark);display:flex;gap:76px;align-items:center;}
body.light-mode #abt-sec{background:var(--bg);}
.abt-t{flex:1;}
.abt-f{flex:1;}
.abt-body{font-size:15px;color:var(--text2);line-height:1.9;margin-top:18px;margin-bottom:36px;}
.fi{display:flex;gap:18px;margin-bottom:16px;padding:15px;background:var(--bg2);border-radius:14px;border:1px solid var(--border);transition:border-color .3s;}
.fi:hover{border-color:rgba(230,51,39,0.5);}
.fic{width:44px;height:44px;min-width:44px;background:rgba(230,51,39,0.12);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:19px;}
.fit h4{font-weight:700;font-size:14px;margin-bottom:3px;color:var(--text);}
.fit p{font-size:12px;color:var(--muted);line-height:1.6;}

/* CONTACT */
#ct-sec{background:var(--darker);text-align:center;}
body.light-mode #ct-sec{background:var(--bg3);}
.ctg{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:18px;max-width:960px;margin:52px auto 0;}
.ctc{background:var(--bg2);border-radius:20px;padding:28px 20px;border:1px solid var(--border);transition:all .3s;text-decoration:none;display:block;cursor:pointer;}
.ctc:hover{border-color:var(--p);transform:translateY(-4px);}
.cticon{font-size:32px;margin-bottom:12px;display:block;}
.ctlb{font-size:11px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:7px;}
.ctv{font-size:16px;font-weight:700;color:var(--text);direction:ltr;}
.hrs-box{margin-top:30px;padding:20px;background:var(--bg2);border-radius:16px;max-width:500px;margin-inline:auto;border:1px solid var(--border);}

footer{background:var(--darker);border-top:1px solid var(--border);padding:32px 60px;display:flex;justify-content:space-between;align-items:center;}
body.light-mode footer{background:var(--bg3);}
.flogo{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:4px;display:flex;align-items:center;gap:10px;}
.flogo span{color:var(--s);}
.flogo img{height:28px;object-fit:contain;display:none;}
.flogo img.show{display:block;}

@media(max-width:768px){
  nav{padding:0 14px;}
  .nav-links{display:none;}
  #mlb{display:flex !important;}
  .hero-content{padding:0 22px;}
  .hero-car{display:none;}
  .hero-stats{right:22px;bottom:36px;gap:22px;}
  .stat-n{font-size:34px;}
  .hero-clock{right:22px;top:88px;padding:10px 14px;min-width:160px;}
  .clock-time{font-size:28px;}
  section{padding:56px 22px;}
  #abt-sec{flex-direction:column;gap:36px;}
  footer{flex-direction:column;gap:14px;text-align:center;padding:26px 22px;}
  #adm{width:100%;}
  .det-gall{height:240px;}
  .ctg{grid-template-columns:1fr 1fr;}
}
</style>
</head>
<body>

<div id="ls"><div class="ll">BYD <span>|</span> فرۆشگا</div><div class="lb"><div class="lf"></div></div></div>
